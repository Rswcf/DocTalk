+                    continue
+                total += 1
+                cp = ord(c)
+                if c == "�" or unicodedata.category(c)[0] in ("C", "S") or 0xE000 <= cp <= 0xF8FF:
+                    bad += 1
+    return bad / total if total else 0.0
